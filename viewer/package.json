{
  "name": "tensorgrad-viewer",
  "version": "0.0.1",
  "private": true,
  "description": "Renders a tensorgrad compiled Graph as an interactive DAG (Graphviz via @viz-js/viz).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "@viz-js/viz": "^3.27.0",
    "tensorgrad": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
